---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "SaunaMind tracks your heat adaptation over time — guided by peer-reviewed research. Know your zones. Not just your time." } = Astro.props;
const homeHref = import.meta.env.BASE_URL;
const privacyHref = `${import.meta.env.BASE_URL}privacy/`;
const supportHref = `${import.meta.env.BASE_URL}support/`;
const canonical = `https://sauna-mind.com${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Instagram, WhatsApp, iMessage previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://sauna-mind.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="SaunaMind" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://sauna-mind.com/og-image.png" />

    <!-- App Store -->
    <meta name="apple-itunes-app" content="app-id=6739606516" />

    <!-- Structured data for Google -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "MobileApplication",
      "name": "SaunaMind",
      "description": "The world's first recovery intelligence platform for heat exposure. Tracks your heat adaptation across five physiological zones.",
      "operatingSystem": "iOS",
      "applicationCategory": "HealthApplication",
      "url": "https://sauna-mind.com",
      "offers": { "@type": "Offer", "price": "19.99", "priceCurrency": "USD" },
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "ratingCount": "1" }
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --cream: #F0EDE6;
        --cream-dim: #D8D4CC;
        --orange: #E85D04;
        --orange-light: #FF7A1F;
        --dark: #0A0907;
        --dark2: #131109;
        --dark3: #1C1A14;
        --dark4: #252218;
        --border: rgba(240,237,230,0.08);
        --border-2: rgba(240,237,230,0.12);
        --zone-blue: #3B8BF5;
        --zone-green: #22D47A;
        --zone-amber: #F5A623;
        --zone-red: #F53B3B;
        --zone-danger: #C41717;
      }
      *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
      html { scroll-behavior:smooth; -webkit-font-smoothing:antialiased; }
      body { background:var(--dark); color:var(--cream); font-family:'Barlow',sans-serif; overflow-x:hidden; }

      /* LOGO */
      .sm-logo { display:inline-flex; align-items:center; gap:10px; text-decoration:none; }
      .sm-logo img { flex-shrink:0; }
      .sm-logo-text {
        font-family:'Barlow Condensed',sans-serif; font-weight:800; font-size:14px;
        color:var(--orange); letter-spacing:0.2em; text-transform:uppercase;
      }
      .sm-hero-logo-wrap { display:flex; flex-direction:column; align-items:center; gap:16px; margin-bottom:36px; }
      .sm-hero-logo-text {
        font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:28px;
        color:var(--cream); letter-spacing:0.12em; text-transform:uppercase;
      }
      .sm-hero-logo-sub {
        font-family:'Barlow Condensed',sans-serif; font-weight:300; font-size:14px;
        color:var(--cream-dim); letter-spacing:0.25em; text-transform:uppercase;
      }

      /* NAV */
      .sm-nav {
        position:fixed; top:0; left:0; right:0; z-index:100;
        background:rgba(10,9,7,0.92); backdrop-filter:blur(20px);
        border-bottom:1px solid rgba(232,93,4,0.15);
        padding:16px 48px; display:flex; align-items:center; justify-content:space-between;
        transition:box-shadow 0.3s;
      }
      .sm-nav-links { display:flex; align-items:center; gap:32px; }
      .sm-nav-link {
        font-family:'Barlow Condensed',sans-serif; font-size:13px; font-weight:600;
        letter-spacing:0.12em; text-transform:uppercase;
        color:var(--cream-dim); text-decoration:none; transition:color 0.2s;
      }
      .sm-nav-link:hover { color:var(--orange); }
      .sm-nav-btn {
        background:var(--orange); color:#fff; border:none;
        padding:10px 24px;
        font-family:'Barlow Condensed',sans-serif; font-size:13px; font-weight:700;
        letter-spacing:0.1em; text-transform:uppercase;
        cursor:pointer; transition:all 0.2s;
      }
      .sm-nav-btn:hover { background:var(--orange-light); transform:translateY(-1px); }

      /* HERO */
      .sm-hero {
        min-height:100vh; display:flex; flex-direction:column; align-items:center;
        justify-content:center; text-align:center; padding:60px 24px 40px;
        position:relative; overflow:hidden; background:var(--dark);
      }
      .sm-hero-glow {
        position:absolute; width:800px; height:800px; pointer-events:none;
        top:50%; left:50%; transform:translate(-50%,-58%);
        background:
          radial-gradient(ellipse 60% 50% at 50% 60%, rgba(232,93,4,0.08) 0%, transparent 70%),
          radial-gradient(ellipse 40% 30% at 30% 20%, rgba(59,139,245,0.05) 0%, transparent 60%);
        animation:sm-breathe 7s ease-in-out infinite;
      }
      @keyframes sm-breathe { 0%,100% { transform:translate(-50%,-58%) scale(1); opacity:1; } 50% { transform:translate(-50%,-58%) scale(1.1); opacity:0.6; } }
      .sm-hero-eyebrow {
        font-family:'Barlow Condensed',sans-serif; font-weight:400; font-size:13px;
        letter-spacing:0.25em; text-transform:uppercase;
        color:var(--orange); margin-bottom:16px;
      }
      .sm-hero-h1 {
        font-family:'Barlow Condensed',sans-serif; font-weight:900;
        font-size:clamp(64px,12vw,140px); line-height:0.88;
        margin-bottom:24px; letter-spacing:-0.01em; color:var(--cream);
      }
      .sm-hero-h1 .sm-orange { color:var(--orange); display:block; }
      .sm-hero-explainer {
        font-family:'Barlow Condensed',sans-serif; font-weight:300;
        font-size:clamp(18px,2.5vw,28px); letter-spacing:0.18em; text-transform:uppercase;
        color:var(--cream-dim); max-width:600px; line-height:1.4; margin-bottom:16px;
      }
      .sm-hero-sub {
        font-size:17px; color:var(--cream-dim); max-width:520px; line-height:1.65; margin-bottom:44px;
        font-weight:500;
      }
      .sm-trust { display:flex; align-items:center; justify-content:center; gap:24px; flex-wrap:wrap; margin-bottom:44px; }
      .sm-trust-item {
        font-family:'Barlow Condensed',sans-serif; font-size:12px; font-weight:600;
        letter-spacing:0.1em; text-transform:uppercase; color:var(--cream-dim);
      }

      /* HERO STAT */
      .sm-hero-stat {
        background:var(--dark3); border:1px solid var(--border);
        padding:36px 48px; margin:0 auto 44px auto; display:block;
        text-align:center; max-width:600px; transition:opacity 0.6s ease;
      }
      .sm-hero-stat-num {
        font-family:'Barlow Condensed',sans-serif; font-weight:900;
        font-size:56px; color:var(--orange); line-height:1; margin-bottom:10px;
      }
      .sm-hero-stat-label { font-size:13px; color:var(--cream-dim); line-height:1.5; }
      .sm-hero-stat.sm-fade-out { opacity:0; }

      /* HERO FORM */
      .sm-hero-form { display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-bottom:16px; }
      .sm-email-input {
        background:var(--dark3); border:1px solid rgba(232,93,4,0.2);
        padding:14px 24px;
        font-family:'Barlow',sans-serif; font-size:15px; color:var(--cream);
        outline:none; width:290px; transition:border-color 0.2s;
      }
      .sm-email-input::placeholder { color:rgba(200,196,188,0.4); }
      .sm-email-input:focus { border-color:var(--orange); }
      .sm-submit-btn {
        background:var(--orange); color:#fff; border:none;
        padding:14px 28px;
        font-family:'Barlow Condensed',sans-serif; font-size:14px; font-weight:700;
        letter-spacing:0.1em; text-transform:uppercase;
        cursor:pointer; transition:all 0.2s; white-space:nowrap;
      }
      .sm-submit-btn:hover { background:var(--orange-light); transform:translateY(-1px); }
      .sm-form-note { font-size:12px; color:rgba(200,196,188,0.3); }
      .sm-success { display:none; color:var(--zone-green); font-size:15px; font-weight:600; margin-bottom:12px; }

      /* STATS BAR */
      .sm-stats {
        display:flex; justify-content:center; flex-wrap:wrap;
        border-top:1px solid rgba(232,93,4,0.12); border-bottom:1px solid rgba(232,93,4,0.12);
        padding:36px 48px; gap:0; background:var(--dark);
      }
      .sm-stat { text-align:center; padding:0 48px; position:relative; }
      .sm-stat + .sm-stat { border-left:1px solid rgba(240,237,230,0.08); }
      .sm-stat-num {
        font-family:'Barlow Condensed',sans-serif; font-weight:900;
        font-size:42px; color:var(--orange); line-height:1; margin-bottom:8px;
      }
      .sm-stat-label {
        font-family:'Barlow Condensed',sans-serif; font-size:11px; font-weight:600;
        letter-spacing:0.2em; text-transform:uppercase; color:var(--cream-dim);
      }

      /* SECTION */
      .sm-section { padding:60px 48px; max-width:1100px; margin:0 auto; }
      .sm-eyebrow {
        font-family:'Barlow Condensed',sans-serif; font-size:11px; font-weight:600;
        letter-spacing:0.3em; text-transform:uppercase;
        color:var(--orange); margin-bottom:16px;
      }
      .sm-h2 {
        font-family:'Barlow Condensed',sans-serif; font-weight:800;
        font-size:clamp(48px,7vw,90px); line-height:0.92;
        margin-bottom:20px; letter-spacing:-0.01em; color:var(--cream);
      }
      .sm-h2 span { color:var(--orange); }
      .sm-section-sub {
        font-size:17px; color:var(--cream-dim); max-width:520px; line-height:1.65; margin-bottom:40px;
        font-weight:500;
      }

      /* SLIDE TITLE (pitch deck style) */
      .sm-slide-label {
        font-family:'Barlow Condensed',sans-serif; font-size:11px; font-weight:600;
        letter-spacing:0.3em; text-transform:uppercase;
        color:var(--orange); margin-bottom:16px;
      }
      .sm-slide-title {
        font-family:'Barlow Condensed',sans-serif; font-weight:800;
        font-size:clamp(42px,5.5vw,70px); line-height:0.92; letter-spacing:-0.01em;
        color:var(--cream); margin-bottom:36px;
      }
      .sm-slide-title em { color:var(--orange); font-style:normal; }

      /* TWO-COL LAYOUT */
      .sm-two-col { display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:start; }
      .sm-three-col { display:grid; grid-template-columns:1fr 1fr 1fr; gap:28px; }

      /* PHASE CARDS */
      .sm-phase-card {
        background:var(--dark3); border:1px solid rgba(240,237,230,0.06);
        padding:24px 20px; text-align:center;
      }
      .sm-phase-num {
        font-family:'Barlow Condensed',sans-serif; font-weight:900;
        font-size:48px; line-height:1; margin-bottom:8px;
      }
      .sm-phase-name {
        font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:15px;
        letter-spacing:0.1em; text-transform:uppercase;
        color:var(--cream); margin-bottom:8px;
      }
      .sm-phase-desc { font-size:13px; color:var(--cream-dim); line-height:1.5; font-weight:500; }
      .sm-phase-footer {
        margin-top:20px; font-size:14px; color:var(--cream-dim); text-align:center;
        letter-spacing:0.05em; font-weight:500;
      }
      .sm-phase-footer strong { color:var(--cream); font-weight:600; }

      /* POINT LIST */
      .sm-point-list { list-style:none; }
      .sm-point-list li {
        padding:10px 0; border-bottom:1px solid rgba(240,237,230,0.06);
        font-size:15px; color:var(--cream-dim); line-height:1.5; font-weight:500;
        display:flex; gap:14px; align-items:flex-start;
      }
      .sm-point-list li:last-child { border-bottom:none; }
      .sm-point-list li::before {
        content:'\2014'; color:var(--orange); flex-shrink:0; font-weight:700; margin-top:1px;
      }
      .sm-point-list li strong { color:var(--cream); font-weight:600; }

      /* SESSION MOCK CARD */
      .sm-mock-card {
        background:var(--dark3); border:1px solid rgba(240,237,230,0.08);
        padding:20px 22px;
      }
      .sm-mock-label {
        font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:13px;
        letter-spacing:0.15em; text-transform:uppercase; margin-bottom:10px;
      }
      .sm-mock-value {
        font-family:'Barlow Condensed',sans-serif; font-weight:900;
        font-size:52px; line-height:1;
      }
      .sm-mock-sub { font-size:12px; color:var(--cream-dim); margin-top:4px; }
      .sm-mock-bar {
        margin-top:12px; height:4px; border-radius:2px;
      }

      /* THERMAL STRIP */
      .sm-thermal-strip {
        height:4px; width:100%;
        background:linear-gradient(90deg, var(--zone-blue), var(--zone-green), var(--zone-amber), var(--zone-red));
        margin-bottom:32px;
      }

      /* ZONE TABLE */
      .sm-color-bar {
        display:flex; overflow:hidden; margin-bottom:36px; height:4px;
        background:linear-gradient(90deg, var(--zone-blue), var(--zone-green), var(--zone-amber), var(--zone-red));
      }
      .sm-table { width:100%; border-collapse:collapse; }
      .sm-table thead tr { border-bottom:1px solid rgba(240,237,230,0.1); }
      .sm-table thead th {
        font-family:'Barlow Condensed',sans-serif; font-size:11px; font-weight:600;
        letter-spacing:0.2em; text-transform:uppercase;
        color:var(--cream-dim); padding:0 16px 18px 16px; text-align:left;
      }
      .sm-table thead th:first-child { padding-left:0; }
      .sm-table tbody tr { border-bottom:1px solid rgba(240,237,230,0.05); transition:background 0.2s; }
      .sm-table tbody tr:hover { background:var(--dark3); }
      .sm-table tbody tr:last-child { border-bottom:none; }
      .sm-table td { padding:22px 16px; vertical-align:middle; }
      .sm-table td:first-child { padding-left:0; }
      .sm-zone-cell { display:flex; align-items:center; gap:14px; }
      .sm-zone-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
      .sm-zone-name {
        font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:15px;
      }
      .sm-zone-temp {
        font-family:'Barlow Condensed',sans-serif; font-size:14px; font-weight:400;
        color:var(--cream-dim);
      }
      .sm-zone-desc { font-size:15px; color:var(--cream-dim); line-height:1.5; font-weight:500; }
      .sm-zone-pill {
        font-family:'Barlow Condensed',sans-serif;
        font-size:11px; font-weight:600;
        letter-spacing:0.15em; text-transform:uppercase;
        padding:5px 14px; display:inline-block; white-space:nowrap;
      }

      /* FORMULA BOX */
      .sm-formula-box {
        background:var(--dark4); border:1px solid rgba(232,93,4,0.3);
        padding:32px; margin-top:48px; text-align:center;
      }
      .sm-formula-label {
        font-family:'Barlow Condensed',sans-serif; font-size:11px; font-weight:600;
        letter-spacing:0.25em; text-transform:uppercase; color:var(--cream-dim); margin-bottom:16px;
      }
      .sm-formula-p { font-size:16px; color:var(--cream-dim); line-height:1.75; font-weight:500; }
      .sm-formula-p strong { color:var(--cream); font-weight:600; }

      /* SCIENCE GRID */
      .sm-science-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:16px; margin-top:24px; }
      .sm-sci-card {
        background:var(--dark3); border:1px solid var(--border);
        padding:28px 32px; transition:border-color 0.3s;
      }
      .sm-sci-card:hover { border-color:rgba(240,237,230,0.15); }
      .sm-sci-card h3 {
        font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:18px;
        margin-bottom:12px; color:var(--cream);
      }
      .sm-sci-card p { font-size:15px; color:var(--cream-dim); line-height:1.65; margin-bottom:20px; font-weight:500; }
      .sm-sci-source {
        font-family:'Barlow Condensed',sans-serif; font-size:11px; font-weight:400;
        letter-spacing:0.05em; color:rgba(200,196,188,0.5);
        border-top:1px solid var(--border); padding-top:14px;
      }
      .sm-sci-latest {
        background:var(--dark3); border:1px solid var(--orange);
        padding:32px; margin-top:40px; transition:border-color 0.3s;
      }
      .sm-sci-latest:hover { border-color:var(--orange-light); }
      .sm-sci-latest h3 {
        font-family:'Barlow Condensed',sans-serif; font-weight:800; font-size:22px;
        margin-bottom:12px; color:var(--cream);
      }
      .sm-sci-latest p { font-size:15px; color:var(--cream-dim); line-height:1.65; margin-bottom:20px; }
      .sm-sci-latest-badge {
        display:inline-block; background:var(--orange); color:#fff;
        font-family:'Barlow Condensed',sans-serif;
        font-size:10px; font-weight:700; letter-spacing:0.2em;
        text-transform:uppercase; padding:4px 12px; margin-bottom:16px;
      }

      /* SAUNA TYPES COMPARISON */
      .sm-type-card { background:var(--dark3); border:1px solid var(--border); overflow:hidden; }
      .sm-type-inner { padding:32px; }
      .sm-type-title {
        font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:20px;
        letter-spacing:0.08em; text-transform:uppercase; margin-bottom:24px; color:var(--cream);
      }
      .sm-type-row { display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid rgba(240,237,230,0.05); }
      .sm-type-row:last-child { border-bottom:none; }
      .sm-type-key { font-size:14px; color:var(--cream-dim); }
      .sm-type-val {
        font-family:'Barlow Condensed',sans-serif; font-size:14px; font-weight:600; color:var(--cream);
      }
      .sm-type-badge {
        display:block; text-align:center; margin:24px 16px 0 16px; padding:12px;
        font-family:'Barlow Condensed',sans-serif; font-size:12px; font-weight:700;
        letter-spacing:0.1em; text-transform:uppercase;
      }
      .sm-cmp-table { width:100%; border-collapse:collapse; }
      .sm-cmp-table thead th {
        font-family:'Barlow Condensed',sans-serif; font-size:16px; font-weight:800;
        letter-spacing:0.08em; text-transform:uppercase; padding:0 16px 20px 16px; text-align:center;
        color:var(--cream);
      }
      .sm-cmp-table thead th:first-child { text-align:left; }
      .sm-cmp-table tbody td {
        padding:14px 16px; text-align:center; border-bottom:1px solid rgba(240,237,230,0.05);
        font-family:'Barlow Condensed',sans-serif; font-size:14px; font-weight:600; color:var(--cream);
      }
      .sm-cmp-table tbody td:first-child {
        text-align:left; font-family:'Barlow',sans-serif; font-size:14px;
        font-weight:400; color:var(--cream-dim);
      }
      .sm-cmp-table tfoot td { padding:20px 16px 0 16px; text-align:center; }
      .sm-type-source {
        font-family:'Barlow Condensed',sans-serif; font-size:11px;
        color:rgba(200,196,188,0.25); margin-top:48px;
      }

      /* PRICING SECTION */
      .sm-pricing-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:28px; margin-bottom:28px; }
      .sm-pricing-card {
        background:var(--dark3); border:1px solid var(--border);
        padding:32px 28px; position:relative;
      }
      .sm-pricing-card.featured {
        border-color:var(--orange); background:rgba(232,93,4,0.07);
      }
      .sm-pricing-badge {
        position:absolute; top:-1px; right:20px;
        background:var(--orange);
        font-family:'Barlow Condensed',sans-serif;
        font-size:10px; font-weight:700; letter-spacing:0.2em;
        text-transform:uppercase; color:#fff; padding:4px 12px;
      }
      .sm-pricing-tier {
        font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:16px;
        letter-spacing:0.1em; text-transform:uppercase;
        color:var(--cream-dim); margin-bottom:12px;
      }
      .sm-pricing-price {
        font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:52px;
        line-height:1; color:var(--cream); margin-bottom:4px;
      }
      .sm-pricing-period { font-size:12px; color:var(--cream-dim); margin-bottom:16px; }
      .sm-pricing-spots {
        font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:12px;
        letter-spacing:0.15em; text-transform:uppercase;
        color:var(--orange); margin-bottom:20px;
      }
      .sm-pricing-desc { font-size:14px; color:var(--cream-dim); line-height:1.5; font-weight:500; }

      /* METRICS ROW */
      .sm-metrics-row { display:flex; gap:20px; }
      .sm-metric {
        flex:1; background:var(--dark4);
        border-top:2px solid var(--orange);
        padding:20px 20px 16px; text-align:center;
      }
      .sm-metric-val {
        font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:40px;
        color:var(--cream); line-height:1;
      }
      .sm-metric-val span { color:var(--orange); font-size:24px; }
      .sm-metric-lab { font-size:12px; color:var(--cream-dim); margin-top:6px; }

      /* DOWNLOAD / WAITLIST */
      .sm-waitlist {
        text-align:center; padding:80px 24px; position:relative; overflow:hidden;
        background:var(--dark);
      }
      .sm-waitlist-glow {
        position:absolute; width:600px; height:400px;
        background:radial-gradient(ellipse,rgba(232,93,4,0.08) 0%,transparent 70%);
        top:50%; left:50%; transform:translate(-50%,-50%); pointer-events:none;
      }
      .sm-waitlist-inner { max-width:560px; margin:0 auto; position:relative; }
      .sm-waitlist h2 {
        font-family:'Barlow Condensed',sans-serif; font-weight:900;
        font-size:clamp(56px,10vw,110px); line-height:0.92;
        margin-bottom:20px; letter-spacing:-0.01em; color:var(--cream);
      }
      .sm-waitlist h2 span { color:var(--orange); }
      .sm-waitlist-p { font-size:17px; color:var(--cream-dim); line-height:1.65; margin-bottom:32px; font-weight:500; }
      .sm-waitlist-form { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; }

      /* TEMP SLIDER */
      .sm-slider-wrap { padding:48px; max-width:700px; margin:0 auto; text-align:center; }
      .sm-slider-temp {
        font-family:'Barlow Condensed',sans-serif; font-weight:900;
        font-size:72px; line-height:1; margin-bottom:6px; transition:color 0.3s;
      }
      .sm-slider-zone {
        font-family:'Barlow Condensed',sans-serif; font-weight:700;
        font-size:22px; margin-bottom:6px; transition:color 0.3s;
      }
      .sm-slider-desc { font-size:14px; color:var(--cream-dim); margin-bottom:36px; min-height:24px; transition:color 0.3s; }
      .sm-slider-track {
        position:relative; width:100%; height:4px; margin-bottom:16px;
        background:linear-gradient(90deg, var(--zone-blue) 0%, var(--zone-green) 25%, var(--zone-amber) 50%, var(--zone-red) 75%, var(--zone-danger) 100%);
      }
      .sm-slider-input {
        -webkit-appearance:none; appearance:none; width:100%; height:12px;
        background:transparent; position:relative; cursor:pointer; margin:-4px 0 0 0; outline:none;
      }
      .sm-slider-input::-webkit-slider-thumb {
        -webkit-appearance:none; appearance:none; width:20px; height:20px;
        background:var(--cream); border:3px solid var(--dark);
        box-shadow:0 0 12px rgba(240,237,230,0.3); cursor:pointer;
      }
      .sm-slider-input::-moz-range-thumb {
        width:20px; height:20px; background:var(--cream);
        border:3px solid var(--dark); box-shadow:0 0 12px rgba(240,237,230,0.3); cursor:pointer;
      }
      .sm-slider-range {
        display:flex; justify-content:space-between;
        font-family:'Barlow Condensed',sans-serif; font-size:11px;
        letter-spacing:0.1em; color:rgba(200,196,188,0.3);
      }

      /* FOOTER */
      .sm-footer {
        border-top:1px solid rgba(232,93,4,0.12); padding:32px 48px;
        display:flex; align-items:center; justify-content:space-between;
        flex-wrap:wrap; gap:16px; background:var(--dark);
      }
      .sm-footer-links { display:flex; gap:20px; flex-wrap:wrap; }
      .sm-footer-link {
        color:var(--cream-dim); text-decoration:none;
        font-family:'Barlow Condensed',sans-serif; font-size:12px; font-weight:600;
        letter-spacing:0.1em; text-transform:uppercase; transition:color 0.2s;
      }
      .sm-footer-link:hover { color:var(--orange); }
      .sm-footer-slogan {
        font-family:'Barlow Condensed',sans-serif; font-size:13px; font-weight:700;
        letter-spacing:0.15em; text-transform:uppercase; color:var(--orange);
      }
      .sm-footer-copy { font-size:12px; color:rgba(200,196,188,0.3); }

      /* ZONE PILLS (cover-style) */
      .sm-zone-pills { display:flex; gap:8px; justify-content:center; flex-wrap:wrap; margin-top:32px; }
      .sm-zone-pill-item {
        font-family:'Barlow Condensed',sans-serif;
        font-size:11px; font-weight:600;
        letter-spacing:0.15em; text-transform:uppercase;
        padding:5px 14px;
      }

      /* RESPONSIVE */
      @media(max-width:1024px) {
        .sm-nav { padding:14px 24px; }
        .sm-nav-links { gap:20px; }
        .sm-section { padding:48px 32px; }
        .sm-h2 { font-size:clamp(40px,6vw,72px); }
        .sm-science-grid { grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); }
        .sm-pricing-grid { grid-template-columns:1fr; max-width:400px; margin-left:auto; margin-right:auto; }
        .sm-metrics-row { flex-wrap:wrap; }
        .sm-two-col { grid-template-columns:1fr; gap:32px; }
        .sm-three-col { grid-template-columns:1fr; }
        .sm-metric { min-width:140px; }
      }
      @media(max-width:768px) {
        .sm-nav { padding:14px 20px; }
        .sm-nav-links .sm-nav-link { display:none; }
        .sm-nav .sm-logo-text { display:none; }
        .sm-nav-btn { padding:9px 16px; font-size:12px; }
        .sm-hero { padding:80px 20px 40px; }
        .sm-hero-stat { padding:24px 20px; margin-bottom:32px; }
        .sm-hero-stat-num { font-size:40px; }
        .sm-hero-stat-label { font-size:12px; }
        .sm-hero-form { flex-direction:column; align-items:stretch; padding:0 8px; }
        .sm-email-input { width:100%; }
        .sm-submit-btn { width:100%; }
        .sm-trust { flex-direction:column; align-items:center; gap:10px; }
        .sm-section { padding:40px 20px; }
        .sm-stats { padding:24px 16px; }
        .sm-stat { padding:16px 20px; border-left:none !important; }
        .sm-stat + .sm-stat { border-top:1px solid rgba(240,237,230,0.08); }
        .sm-sci-latest { padding:24px 20px; margin-top:24px; }
        .sm-sci-latest h3 { font-size:18px; }
        .sm-science-grid { grid-template-columns:1fr; }
        .sm-sci-card { padding:24px 20px; }
        .sm-formula-box { padding:24px 20px; }
        .sm-waitlist { padding:48px 20px; }
        .sm-waitlist h2 { font-size:clamp(44px,12vw,80px); }
        .sm-waitlist-form { flex-direction:column; align-items:stretch; padding:0 8px; }
        .sm-footer { padding:24px; flex-direction:column; align-items:flex-start; gap:12px; }
        .sm-table thead th:nth-child(3), .sm-table td:nth-child(3) { display:none; }
        .sm-types-grid { grid-template-columns:1fr; }
        .sm-type-inner { padding:16px; overflow-x:auto; -webkit-overflow-scrolling:touch; }
        .sm-cmp-table { min-width:420px; }
        .sm-cmp-table thead th { font-size:14px; padding:0 10px 14px 10px; }
        .sm-cmp-table tbody td { padding:10px; font-size:12px; }
        .sm-cmp-table tbody td:first-child { font-size:12px; }
        .sm-cmp-table tfoot td { padding:14px 10px 0 10px; }
        .sm-type-badge { font-size:10px; padding:4px 10px; }
        .sm-slider-wrap { padding:36px 20px; }
        .sm-slider-temp { font-size:48px; }
        .sm-slider-zone { font-size:18px; }
        .sm-slider-desc { font-size:13px; }
        .sm-pricing-grid { grid-template-columns:1fr; }
        .sm-metrics-row { flex-direction:column; }
        .sm-zone-pills { flex-wrap:wrap; gap:6px; }
      }
      @media(max-width:480px) {
        .sm-hero-h1 { font-size:clamp(44px,14vw,80px); }
        .sm-hero-explainer { font-size:16px; }
        .sm-stat-num { font-size:30px; }
        .sm-h2 { font-size:clamp(36px,11vw,60px); }
        .sm-section-sub { font-size:15px; }
        .sm-nav-btn { padding:8px 12px; font-size:11px; }
        .sm-footer-links { flex-wrap:wrap; gap:12px; }
      }
    </style>
  </head>
  <body>
    <slot />
    <footer class="sm-footer">
      <a href={homeHref} class="sm-logo">
        <img src="/logo.png" alt="SaunaMind" width="28" height="28" style="opacity:0.4">
      </a>
      <div class="sm-footer-links">
        <a class="sm-footer-link" href="https://instagram.com/thesaunamind" target="_blank" rel="noopener">Instagram</a>
        <a class="sm-footer-link" href={privacyHref}>Privacy</a>
        <a class="sm-footer-link" href={supportHref}>Support</a>
      </div>
      <div class="sm-footer-slogan">Know your zones.</div>
      <div class="sm-footer-copy">&copy; 2026 SaunaMind</div>
    </footer>
  </body>
</html>
