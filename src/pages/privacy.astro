---
import Layout from '../layouts/Layout.astro';

const homeHref = import.meta.env.BASE_URL;
const supportHref = `${import.meta.env.BASE_URL}support/`;
const guideHref = `${import.meta.env.BASE_URL}guide/`;
---

<Layout title="Privacy Policy - SaunaMind">
	<nav class="sm-nav">
		<a href={homeHref} class="sm-logo">
			<img src="/logo.png" alt="SaunaMind" width="40" height="40">
			<span class="sm-logo-text">SaunaMind</span>
		</a>
		<div class="sm-nav-links">
			<a class="sm-nav-link" href={homeHref}>Home</a>
			<a class="sm-nav-link" href={guideHref}>Guide</a>
			<a class="sm-nav-link" href={supportHref}>Support</a>
		</div>
	</nav>

	<div class="doc-container">
		<h1>Privacy Policy</h1>
		<p><strong>Last Updated: March 27, 2026</strong></p>
		<h2>Introduction</h2>
		<p>SaunaMind ("we," "our," or "us") is committed to protecting your privacy. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website and use our services.</p>
		<h2>Information We Collect</h2>
		<p>We collect information you voluntarily provide to us, including:</p>
		<ul>
			<li><strong>Email Address:</strong> When you sign up for early access or subscribe to our waitlist</li>
			<li><strong>Usage Data:</strong> Information about how you interact with our website via analytics</li>
			<li><strong>Device Information:</strong> Device type, browser type, and IP address</li>
		</ul>
		<h2>How We Use Your Information</h2>
		<p>We use the information we collect to:</p>
		<ul>
			<li>Send you notifications about product launches and updates</li>
			<li>Improve and optimize our website and services</li>
			<li>Comply with legal obligations</li>
			<li>Prevent fraud and enhance security</li>
		</ul>
		<h2>Data Security</h2>
		<p>We implement appropriate technical and organizational measures to protect your personal data against unauthorized access, alteration, disclosure, or destruction. However, no method of transmission over the internet is 100% secure.</p>
		<h2>Third-Party Services</h2>
		<p>We use Netlify Forms for contact form submissions. Netlify's privacy practices are governed by their own privacy policy. We encourage you to review their policy independently.</p>
		<h2>Cookies</h2>
		<p>We may use cookies and similar tracking technologies to enhance your browsing experience. You can control cookie settings through your browser preferences.</p>
		<h2>Your Rights</h2>
		<p>Depending on your location, you may have the right to:</p>
		<ul>
			<li>Access your personal data</li>
			<li>Request correction or deletion of your data</li>
			<li>Opt-out of marketing communications</li>
		</ul>
		<h2>Changes to This Policy</h2>
		<p>We may update this Privacy Policy from time to time. Changes will be effective when posted on this page with an updated Last Updated date.</p>
		<h2>Contact Us</h2>
		<p>If you have questions about this Privacy Policy or our privacy practices, please contact us at privacy@saunamind.com.</p>
	</div>
</Layout>

<style>
  .doc-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 48px;
  }

  .doc-container h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(40px, 7vw, 64px);
    letter-spacing: -0.01em;
    color: var(--cream);
    margin-bottom: 8px;
  }

  .doc-container > p:first-of-type {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--cream-dim);
    margin-bottom: 48px;
  }

  .doc-container h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 22px;
    color: var(--orange);
    margin-top: 44px;
    margin-bottom: 14px;
    letter-spacing: 0.05em;
  }

  .doc-container p,
  .doc-container li {
    font-size: 15px;
    color: var(--cream-dim);
    line-height: 1.8;
  }

  .doc-container p { margin-bottom: 16px; }
  .doc-container ul { margin-left: 24px; margin-bottom: 16px; }
  .doc-container li { margin-bottom: 8px; }
  .doc-container strong { color: var(--cream); }

  @media (max-width: 768px) {
    .doc-container { padding: 60px 20px; }
  }
</style>
