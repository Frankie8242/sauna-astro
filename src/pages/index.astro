---
import Layout from '../layouts/Layout.astro';

const homeHref = import.meta.env.BASE_URL;
const privacyHref = `${import.meta.env.BASE_URL}privacy/`;
const supportHref = `${import.meta.env.BASE_URL}support/`;
const guideHref = `${import.meta.env.BASE_URL}guide/`;
---

<Layout title="SaunaMind - Know Your Zones">
	<!-- NAV -->
	<nav class="sm-nav">
		<a href={homeHref} class="sm-logo">
			<img src="/logo.png" alt="SaunaMind" width="40" height="40">
			<span class="sm-logo-text">SaunaMind</span>
		</a>
		<div class="sm-nav-links">
			<a class="sm-nav-link" href="#zones">The Science</a>
			<a class="sm-nav-link" href="#research">Research</a>
			<a class="sm-nav-link" href="#pricing">Pricing</a>
			<a class="sm-nav-link" href={guideHref}>Guide</a>
			<a class="sm-nav-link" href={privacyHref}>Privacy</a>
			<a class="sm-nav-link" href={supportHref}>Support</a>
			<a class="sm-nav-btn" href="https://apps.apple.com/app/saunamind" style="text-decoration:none;">Download</a>
		</div>
	</nav>

	<!-- HERO -->
	<section class="sm-hero">
		<div class="sm-thermal-bar"></div>
		<div class="sm-hero-glow"></div>
		<div style="position:relative;z-index:2;text-align:center;display:flex;flex-direction:column;align-items:center;">
			<div class="sm-hero-logo-wrap">
				<img src="/logo.png" alt="SaunaMind" width="100" height="100">
				<div class="sm-hero-logo-sub">Physiological Recovery Intelligence</div>
			</div>
			<h1 class="sm-hero-h1">KNOW YOUR<br>ZONES.<span class="sm-orange">FEEL THE SCIENCE.</span></h1>
			<p class="sm-hero-sub" style="margin-bottom:32px;">Every other sauna app runs a timer. SaunaMind tracks what's actually happening inside your body — guided by peer-reviewed research.</p>
			<div class="sm-zone-pills" style="margin-top:0; margin-bottom:40px;">
				<div class="sm-zone-pill-item" style="background:rgba(59,139,245,0.15);color:var(--zone-blue);">Warm Up</div>
				<div class="sm-zone-pill-item" style="background:rgba(34,212,122,0.15);color:var(--zone-green);">Adaptation</div>
				<div class="sm-zone-pill-item" style="background:rgba(245,166,35,0.15);color:var(--zone-amber);">HSP Activation</div>
				<div class="sm-zone-pill-item" style="background:rgba(245,59,59,0.15);color:var(--zone-red);">Deep Hormesis</div>
				<div class="sm-zone-pill-item" style="background:rgba(196,23,23,0.15);color:var(--zone-danger);">Caution</div>
			</div>
			<a href="https://apps.apple.com/app/saunamind" style="display:inline-block;">
				<img src="/appstore-badge.svg" alt="Download on the App Store" width="180" height="60" style="transition:transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
			</a>
			<div style="margin-top:16px; font-family:'Barlow Condensed',sans-serif; font-size:13px; letter-spacing:0.1em; color:var(--cream-dim);">
				<strong style="color:var(--orange);">Founding Members</strong> &mdash; <strong style="color:var(--cream);">$19.99/yr</strong> &middot; locked forever
			</div>
		</div>
	</section>

	<!-- STATS -->
	<div class="sm-stats">
		<div class="sm-stat"><div class="sm-stat-num">5</div><div class="sm-stat-label">Physiological Zones</div></div>
		<div class="sm-stat"><div class="sm-stat-num">20yr</div><div class="sm-stat-label">Research Foundation</div></div>
		<div class="sm-stat"><div class="sm-stat-num">2,315</div><div class="sm-stat-label">Finnish Study Participants</div></div>
		<div class="sm-stat"><div class="sm-stat-num">5&times;</div><div class="sm-stat-label">GH Surge at Peak Zone</div></div>
	</div>

	<!-- THE SOLUTION -->
	<section style="background:var(--dark); border-top:1px solid rgba(232,93,4,0.12);">
		<div class="sm-section">
			<div class="sm-slide-label">The Solution</div>
			<div class="sm-slide-title">Guides optimal heat<br>exposure. <em>From your HR.</em></div>
			<div class="sm-thermal-strip" style="margin-bottom:32px;"></div>
			<div class="sm-three-col">
				<div class="sm-phase-card">
					<div class="sm-phase-num" style="color:var(--zone-amber);">eCBT</div>
					<div class="sm-phase-name">Live Temperature</div>
					<div class="sm-phase-desc">Physiology-informed thermal estimation using peer-reviewed Jay &amp; Kenny 2010 formula</div>
				</div>
				<div class="sm-phase-card">
					<div class="sm-phase-num" style="color:var(--orange);">5</div>
					<div class="sm-phase-name">Thermal Zones</div>
					<div class="sm-phase-desc">Science-backed benefit zones from Warm Up through HSP Activation to Caution ceiling</div>
				</div>
				<div class="sm-phase-card">
					<div class="sm-phase-num" style="color:var(--zone-blue);">3</div>
					<div class="sm-phase-name">Cold Phases</div>
					<div class="sm-phase-desc">Entry Shock &rarr; Adaptation &rarr; Recovery. The only app that models the full cold plunge response</div>
				</div>
			</div>
			<div class="sm-phase-footer">
				Works with <strong>any Bluetooth HR monitor</strong> &middot; Sauna &middot; Cold Plunge &middot; Contrast &middot; Training &middot; AI Coaching
			</div>
		</div>
	</section>

	<!-- ZONES -->
	<section id="zones" style="background:var(--dark); border-top:1px solid rgba(232,93,4,0.12);">
		<div class="sm-section">
			<div class="sm-eyebrow">The 5-Zone System</div>
			<h2 class="sm-h2">Heat has <span>zones.</span></h2>
			<p class="sm-section-sub">Your physiological heat response — not minutes — is what the peer-reviewed research actually tracks.</p>
			<div class="sm-color-bar"></div>
			<table class="sm-table">
				<thead><tr><th>Zone</th><th>eCBT Range</th><th>Effect</th><th>Benefit</th></tr></thead>
				<tbody>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:var(--zone-blue)"></div><span class="sm-zone-name" style="color:var(--zone-blue)">Warm-Up</span></div></td>
						<td><span class="sm-zone-temp">37.0 &ndash; 37.5&deg;C</span></td>
						<td class="sm-zone-desc">Blood flow to skin &middot; mild CV response</td>
						<td><span class="sm-zone-pill" style="background:rgba(59,139,245,0.1);color:var(--zone-blue)">Preparation</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:var(--zone-green)"></div><span class="sm-zone-name" style="color:var(--zone-green)">Heat Adaptation</span></div></td>
						<td><span class="sm-zone-temp">37.5 &ndash; 38.0&deg;C</span></td>
						<td class="sm-zone-desc">Plasma volume &uarr; &middot; CV system adapting</td>
						<td><span class="sm-zone-pill" style="background:rgba(34,212,122,0.1);color:var(--zone-green)">Endurance</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:var(--zone-amber)"></div><span class="sm-zone-name" style="color:var(--zone-amber)">HSP Activation</span></div></td>
						<td><span class="sm-zone-temp">38.0 &ndash; 38.5&deg;C</span></td>
						<td class="sm-zone-desc">Heat shock proteins &middot; cellular repair begins</td>
						<td><span class="sm-zone-pill" style="background:rgba(245,166,35,0.1);color:var(--zone-amber)">Recovery</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:var(--zone-red)"></div><span class="sm-zone-name" style="color:var(--zone-red)">Deep Hormesis</span></div></td>
						<td><span class="sm-zone-temp">38.5 &ndash; 39.0&deg;C</span></td>
						<td class="sm-zone-desc">GH 2&ndash;5&times; baseline &middot; BDNF rises &middot; longevity markers peak</td>
						<td><span class="sm-zone-pill" style="background:rgba(245,59,59,0.1);color:var(--zone-red)">Longevity</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:var(--zone-danger)"></div><span class="sm-zone-name" style="color:var(--zone-danger)">Caution</span></div></td>
						<td><span class="sm-zone-temp">39.0&deg;C+</span></td>
						<td class="sm-zone-desc">Heat stress risk zone &middot; benefits plateau</td>
						<td><span class="sm-zone-pill" style="background:rgba(196,23,23,0.1);color:var(--zone-danger)">Risk Zone</span></td>
					</tr>
				</tbody>
			</table>
			<div class="sm-formula-box">
				<div class="sm-formula-label">Why not time?</div>
				<p class="sm-formula-p">Two people spending 15 minutes in the same sauna will have completely different heat adaptation responses — depending on fitness, resting heart rate, and acclimatisation.<br><br><strong>Time is a guess. Your physiology is the data.</strong></p>
			</div>
		</div>
	</section>

	<!-- PRODUCT -->
	<section style="background:var(--dark); border-top:1px solid rgba(232,93,4,0.12);">
		<div class="sm-section">
			<div class="sm-slide-label">Product</div>
			<div class="sm-slide-title">One tap. <em>Full physiology.</em></div>
			<div class="sm-two-col">
				<div>
					<ul class="sm-point-list">
						<li><strong>Live eCBT display</strong> &mdash; zone color gradient shifts as your body heats up</li>
						<li><strong>Real-time HR curve</strong> &mdash; heat adaptation plotted over session time</li>
						<li><strong>Multi-phase sessions</strong> &mdash; Training + Sauna + Cold in one flow</li>
						<li><strong>AI Recovery Coach</strong> &mdash; full session context and thermal science</li>
						<li><strong>Session history</strong> &mdash; zone transitions and per-phase breakdown</li>
						<li><strong>PDF export</strong> &mdash; shareable session reports</li>
					</ul>
				</div>
				<div style="display:flex;flex-direction:column;gap:12px;">
					<div class="sm-mock-card">
						<div class="sm-mock-label" style="color:var(--orange);">Active Session</div>
						<div class="sm-mock-value" style="color:var(--zone-amber);">38.3&deg;C</div>
						<div class="sm-mock-sub">HSP Activation Zone &middot; 23:14 elapsed</div>
						<div class="sm-mock-bar" style="background:linear-gradient(90deg,var(--zone-blue) 0%,var(--zone-green) 40%,var(--zone-amber) 75%,transparent 75%);"></div>
					</div>
					<div class="sm-mock-card">
						<div class="sm-mock-label" style="color:var(--zone-blue);">Cold Plunge &middot; Entry Shock</div>
						<div class="sm-mock-value" style="color:var(--zone-blue);">+34 BPM</div>
						<div class="sm-mock-sub">Sympathetic activation &middot; Vagal recovery in progress</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- SAUNA TYPES -->
	<section style="background:var(--dark); border-top:1px solid rgba(232,93,4,0.12);">
		<div class="sm-section">
			<div class="sm-eyebrow">Sauna Types</div>
			<h2 class="sm-h2">Compare <span>your heat.</span></h2>
			<p class="sm-section-sub">All three drive heat adaptation. But they reach your zones at very different speeds. Here's what the research shows.</p>
			<table class="sm-cmp-table">
				<thead>
					<tr>
						<th></th>
						<th style="color:var(--zone-green);">Infrared</th>
						<th style="color:var(--orange);">Traditional</th>
						<th style="color:var(--zone-blue);">Steam Room</th>
					</tr>
				</thead>
				<tbody>
					<tr><td>Temperature</td><td>45&ndash;60&deg;C</td><td>80&ndash;100&deg;C</td><td>40&ndash;50&deg;C</td></tr>
					<tr><td>Session length</td><td>30&ndash;45 min</td><td>10&ndash;20 min</td><td>15&ndash;20 min</td></tr>
					<tr><td>Time to Zone 3</td><td>&sim;25&ndash;40 min</td><td>&sim;10&ndash;15 min</td><td>&sim;30&ndash;45 min</td></tr>
					<tr><td>Heat method</td><td>Tissue direct</td><td>Air &rarr; skin</td><td>Humid air</td></tr>
					<tr><td>CV impact</td><td>Moderate</td><td>High</td><td>Moderate</td></tr>
					<tr><td>Research</td><td>Growing</td><td>20+ years</td><td>Limited</td></tr>
				</tbody>
				<tfoot>
					<tr>
						<td></td>
						<td><span class="sm-type-badge" style="background:rgba(34,212,122,0.12);color:var(--zone-green);">Longer sessions</span></td>
						<td><span class="sm-type-badge" style="background:rgba(232,93,4,0.12);color:var(--orange);">Fastest to zone</span></td>
						<td><span class="sm-type-badge" style="background:rgba(59,139,245,0.12);color:var(--zone-blue);">Slowest rise</span></td>
					</tr>
				</tfoot>
			</table>
			<div class="sm-type-source">Minson et al. &middot; American Journal of Physiology</div>
		</div>
	</section>

	<!-- SCIENCE -->
	<section id="research" style="background:var(--dark); padding:20px 0 0 0;">
		<div class="sm-section">
			<div class="sm-eyebrow">Peer-Reviewed Research</div>
			<h2 class="sm-h2">The data <span>behind it.</span></h2>
			<p class="sm-section-sub" style="margin-bottom:0">Every zone threshold is grounded in published research. Not wellness trends. Not guesswork.</p>

			<div class="sm-sci-latest">
				<div class="sm-sci-latest-badge">Latest</div>
				<h3>Sauna Use & Dementia Risk</h3>
				<p>Men who used the sauna 4&ndash;7 times per week had a 77% lower risk of developing dementia and a 65% lower risk of Alzheimer's disease compared to those who used it once per week.</p>
				<div class="sm-sci-source">Laukkanen et al. &middot; Age and Ageing &middot; 2017</div>
			</div>

			<div class="sm-science-grid">
				<div class="sm-sci-card"><h3>Cardiovascular Protection</h3><p>Regular sauna use at sufficient heat exposure reduces risk of sudden cardiac death by up to 63% in the largest longitudinal study of its kind.</p><div class="sm-sci-source">Laukkanen et al. &middot; JAMA Internal Medicine &middot; 2018</div></div>
				<div class="sm-sci-card"><h3>Growth Hormone Surge</h3><p>Heat stress triggers a growth hormone surge of 2&ndash;5&times; baseline. The response is dose-dependent — more pronounced at deeper heat adaptation zones.</p><div class="sm-sci-source">Casanueva et al.</div></div>
				<div class="sm-sci-card"><h3>Heat Shock Proteins</h3><p>HSP70 and HSP90 activate when thermal load crosses the &sim;38&deg;C threshold. These molecular chaperones repair damaged proteins and reduce inflammation.</p><div class="sm-sci-source">Hussain et al. &middot; Journal of Applied Physiology &middot; 2019</div></div>
				<div class="sm-sci-card"><h3>BDNF — Brain Growth Factor</h3><p>Brain-derived neurotrophic factor rises significantly with heat exposure. Linked to improved mood, neuroplasticity, and cognitive protection.</p><div class="sm-sci-source">Rhonda Patrick &middot; FoundMyFitness</div></div>
				<div class="sm-sci-card"><h3>Cortisol Reduction</h3><p>Post-session cortisol drops significantly. Heat activates the parasympathetic nervous system — the same pathway triggered by meditation.</p><div class="sm-sci-source">Laukkanen et al. &middot; Kukkonen-Harjula et al.</div></div>
				<div class="sm-sci-card"><h3>Norepinephrine Spike</h3><p>Norepinephrine spikes up to 3&times; during heat exposure — sharpening focus and mood. The effect extends well beyond the session itself.</p><div class="sm-sci-source">Sr&aacute;mek et al. &middot; Journal of Applied Physiology &middot; 2000</div></div>
				<div class="sm-sci-card"><h3>All-Cause Mortality</h3><p>Frequent sauna users show a 40% lower risk of all-cause mortality. The benefit scales with frequency — more sessions, stronger the effect.</p><div class="sm-sci-source">Laukkanen et al. &middot; JAMA Internal Medicine &middot; 2018</div></div>
				<div class="sm-sci-card"><h3>Hypertension in Women</h3><p>Women who used the sauna regularly showed a 46% lower risk of developing high blood pressure — a significant finding for cardiovascular health across sexes.</p><div class="sm-sci-source">Zaccardi et al. &middot; American Journal of Hypertension &middot; 2017</div></div>
				<div class="sm-sci-card"><h3>Plasma Volume Expansion</h3><p>Repeated heat exposure increases plasma volume, improving oxygen delivery to muscles. This adaptation mirrors the effects of moderate aerobic training.</p><div class="sm-sci-source">Minson et al. &middot; American Journal of Physiology &middot; 2000</div></div>
			</div>
		</div>
	</section>

	<!-- PRICING -->
	<section id="pricing" style="background:var(--dark); border-top:1px solid rgba(232,93,4,0.12);">
		<div class="sm-section">
			<div class="sm-eyebrow">Pricing</div>
			<h2 class="sm-h2">Simple. <span>Everything included.</span></h2>
			<p class="sm-section-sub">No feature gates. Every tier gets every feature. Early believers pay less — forever.</p>
			<div class="sm-pricing-grid">
				<div class="sm-pricing-card featured">
					<div class="sm-pricing-badge">Launch Offer</div>
					<div class="sm-pricing-tier">Founding Member</div>
					<div class="sm-pricing-price">$19.99</div>
					<div class="sm-pricing-period">per year</div>
					<div class="sm-pricing-spots">First 1,000 spots</div>
					<div class="sm-pricing-desc">Every feature. Forever at this price. Locked rate for early believers.</div>
				</div>
				<div class="sm-pricing-card">
					<div class="sm-pricing-tier">Early Adopter</div>
					<div class="sm-pricing-price">$39.99</div>
					<div class="sm-pricing-period">per year</div>
					<div class="sm-pricing-spots">Next 1,000 spots</div>
					<div class="sm-pricing-desc">Every feature. Locked rate before standard pricing.</div>
				</div>
				<div class="sm-pricing-card">
					<div class="sm-pricing-tier">Pro</div>
					<div class="sm-pricing-price">$79.99</div>
					<div class="sm-pricing-period">per year</div>
					<div class="sm-pricing-spots">Standard</div>
					<div class="sm-pricing-desc">Every feature. Full price. No feature gates on any tier.</div>
				</div>
			</div>
			<div class="sm-metrics-row">
				<div class="sm-metric">
					<div class="sm-metric-val">7<span>day</span></div>
					<div class="sm-metric-lab">Free trial &middot; no credit card</div>
				</div>
				<div class="sm-metric">
					<div class="sm-metric-val">0<span>ads</span></div>
					<div class="sm-metric-lab">Subscription only &middot; no data selling</div>
				</div>
				<div class="sm-metric">
					<div class="sm-metric-val">BLE</div>
					<div class="sm-metric-lab">Works with any Bluetooth HR strap</div>
				</div>
				<div class="sm-metric">
					<div class="sm-metric-val">5</div>
					<div class="sm-metric-lab">Zones tracked in real-time</div>
				</div>
			</div>
		</div>
	</section>

	<!-- DOWNLOAD -->
	<section class="sm-waitlist" id="join">
		<div class="sm-waitlist-glow"></div>
		<div class="sm-waitlist-inner">
			<h2>DOWNLOAD<br><span>NOW</span></h2>
			<p class="sm-waitlist-p">Available on the App Store. Founding Members get $19.99/yr — locked forever.<br>1,000 spots. Once they're gone, they're gone.</p>
			<a href="https://apps.apple.com/app/saunamind" style="display:inline-block; margin-top:16px;">
				<img src="/appstore-badge.svg" alt="Download on the App Store" width="180" height="60" style="transition:transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
			</a>
		</div>
	</section>

	<!-- ZONE EXPLORER -->
	<section style="background:var(--dark); border-top:1px solid rgba(232,93,4,0.12);">
		<div class="sm-section" style="max-width:800px;">
			<div class="sm-eyebrow" style="text-align:center;">Explore the zones</div>
			<div class="zone-explorer">
				<div class="zone-display">
					<div class="zone-temp" id="zoneTemp">37.0&deg;C</div>
					<div class="zone-name" id="zoneName">Warm-Up</div>
					<div class="zone-desc" id="zoneDesc">Blood flow to skin &middot; mild CV response</div>
				</div>
				<div class="zone-bars">
					<div class="zone-bar active" data-zone="0" style="--zone-color:var(--zone-blue);">
						<div class="zone-bar-fill"></div>
						<div class="zone-bar-label">Warm-Up</div>
						<div class="zone-bar-range">37.0 &ndash; 37.5&deg;C</div>
					</div>
					<div class="zone-bar" data-zone="1" style="--zone-color:var(--zone-green);">
						<div class="zone-bar-fill"></div>
						<div class="zone-bar-label">Heat Adaptation</div>
						<div class="zone-bar-range">37.5 &ndash; 38.0&deg;C</div>
					</div>
					<div class="zone-bar" data-zone="2" style="--zone-color:var(--zone-amber);">
						<div class="zone-bar-fill"></div>
						<div class="zone-bar-label">HSP Activation</div>
						<div class="zone-bar-range">38.0 &ndash; 38.5&deg;C</div>
					</div>
					<div class="zone-bar" data-zone="3" style="--zone-color:var(--zone-red);">
						<div class="zone-bar-fill"></div>
						<div class="zone-bar-label">Deep Hormesis</div>
						<div class="zone-bar-range">38.5 &ndash; 39.0&deg;C</div>
					</div>
					<div class="zone-bar" data-zone="4" style="--zone-color:var(--zone-danger);">
						<div class="zone-bar-fill"></div>
						<div class="zone-bar-label">Caution</div>
						<div class="zone-bar-range">39.0&deg;C+</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
  .sm-thermal-bar {
    position:absolute; top:0; left:0; right:0; height:3px; z-index:3;
    background:linear-gradient(90deg, var(--zone-blue), var(--zone-green), var(--zone-amber), var(--zone-red));
  }

  .zone-explorer {
    margin-top:32px;
  }
  .zone-display {
    text-align:center; margin-bottom:40px;
  }
  .zone-temp {
    font-family:'Barlow Condensed',sans-serif; font-weight:900;
    font-size:64px; line-height:1; margin-bottom:8px;
    transition:color 0.5s ease;
  }
  .zone-name {
    font-family:'Barlow Condensed',sans-serif; font-weight:700;
    font-size:22px; letter-spacing:0.1em; text-transform:uppercase;
    margin-bottom:8px; transition:color 0.5s ease;
  }
