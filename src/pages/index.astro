						<td class="sm-zone-desc">Blood flow to skin &middot; mild CV response</td>
						<td><span class="sm-zone-pill" style="background:rgba(59,139,245,0.1);color:var(--zone-blue)">Preparation</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:var(--zone-green)"></div><span class="sm-zone-name" style="color:var(--zone-green)">Heat Adaptation</span></div></td>
						<td><span class="sm-zone-temp">37.5 &ndash; 38.0&deg;C</span></td>
						<td class="sm-zone-desc">Plasma volume &uarr; &middot; CV system adapting</td>
						<td><span class="sm-zone-pill" style="background:rgba(34,212,122,0.1);color:var(--zone-green)">Endurance</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:var(--zone-amber)"></div><span class="sm-zone-name" style="color:var(--zone-amber)">HSP Activation</span></div></td>
						<td><span class="sm-zone-temp">38.0 &ndash; 38.5&deg;C</span></td>
						<td class="sm-zone-desc">Heat shock proteins &middot; cellular repair begins</td>
						<td><span class="sm-zone-pill" style="background:rgba(245,166,35,0.1);color:var(--zone-amber)">Recovery</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:var(--zone-red)"></div><span class="sm-zone-name" style="color:var(--zone-red)">Deep Hormesis</span></div></td>
						<td><span class="sm-zone-temp">38.5 &ndash; 39.0&deg;C</span></td>
						<td class="sm-zone-desc">GH 2&ndash;5&times; baseline &middot; BDNF rises &middot; longevity markers peak</td>
						<td><span class="sm-zone-pill" style="background:rgba(245,59,59,0.1);color:var(--zone-red)">Longevity</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:var(--zone-danger)"></div><span class="sm-zone-name" style="color:var(--zone-danger)">Caution</span></div></td>
						<td><span class="sm-zone-temp">39.0&deg;C+</span></td>
