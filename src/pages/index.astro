				</div>
			</div>
			<div class="sm-metrics-row">
				<div class="sm-metric">
					<div class="sm-metric-val">7<span>day</span></div>
					<div class="sm-metric-lab">Free trial &middot; no credit card</div>
				</div>
				<div class="sm-metric">
					<div class="sm-metric-val">0<span>ads</span></div>
					<div class="sm-metric-lab">Subscription only &middot; no data selling</div>
				</div>
				<div class="sm-metric">
					<div class="sm-metric-val">$35</div>
					<div class="sm-metric-lab">Polar H10 &middot; all you need</div>
				</div>
				<div class="sm-metric">
					<div class="sm-metric-val">5</div>
					<div class="sm-metric-lab">Zones tracked in real-time</div>
				</div>
			</div>
		</div>
	</section>

	<!-- DOWNLOAD -->
