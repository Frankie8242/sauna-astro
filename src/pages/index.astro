<script is:inline>
var smFacts = [
  { num:'63%', label:'reduction in sudden cardiac death risk \u00b7 Laukkanen et al., 2018' },
  { num:'2\u20135\u00d7', label:'growth hormone surge at peak core temperature \u00b7 Casanueva et al.' },
  { num:'40%', label:'lower risk of all-cause mortality with regular sauna \u00b7 Laukkanen et al.' },
  { num:'3\u00d7', label:'norepinephrine spike during heat exposure \u00b7 Sr\u00e1mek et al., 2000' },
  { num:'46%', label:'lower hypertension risk in women using sauna regularly \u00b7 Zaccardi et al.' },
  { num:'38\u00b0C', label:'core temp threshold for heat shock protein activation \u00b7 Hussain et al.' },
  { num:'77%', label:'lower dementia risk in men using sauna 4\u20137\u00d7 per week \u00b7 Laukkanen et al.' },
  { num:'2,315', label:'participants in the largest sauna longevity study \u00b7 Finnish cohort' },
  { num:'\u2191BDNF', label:'heat exposure boosts brain growth factor linked to mood \u00b7 Rhonda Patrick' },
  { num:'20yr', label:'of peer-reviewed Finnish sauna research \u00b7 University of Eastern Finland' },
  { num:'33\u00b0C', label:'optimal testicular temp for sperm production after heat \u00b7 Mieusset et al.' },
  { num:'5\u00b0C', label:'below body temp \u2014 keep it cool post-sauna to protect fertility \u00b7 WJMH' }
];
var smFactIndex = 0;
setInterval(function() {
  var box = document.querySelector('.sm-hero-stat');
  if(!box) return;
  box.classList.add('sm-fade-out');
  setTimeout(function() {
    smFactIndex = (smFactIndex + 1) % smFacts.length;
    box.querySelector('.sm-hero-stat-num').innerHTML = smFacts[smFactIndex].num;
    box.querySelector('.sm-hero-stat-label').innerHTML = smFacts[smFactIndex].label;
    box.classList.remove('sm-fade-out');
  }, 600);
}, 8000);

(function() {
  var slider = document.getElementById('smTempSlider');
  var tempEl = document.getElementById('sliderTemp');
  var zoneEl = document.getElementById('sliderZone');
  var descEl = document.getElementById('sliderDesc');
  if(!slider || !tempEl || !zoneEl || !descEl) return;

  var zones = [
    { min:370, max:375, name:'Warm-Up', color:'#3B8BF5', desc:'Blood flow to skin \u00b7 mild cardiovascular response' },
    { min:375, max:380, name:'Heat Adaptation', color:'#22D47A', desc:'Sweating peaks \u00b7 plasma volume expansion begins' },
    { min:380, max:385, name:'HSP Activation', color:'#F5A623', desc:'Heat shock proteins deploy \u00b7 cellular repair activated' },
    { min:385, max:390, name:'Deep Hormesis', color:'#F53B3B', desc:'Growth hormone surges \u00b7 maximum cardiovascular benefit' },
    { min:390, max:396, name:'Caution', color:'#C41717', desc:'Diminishing returns \u00b7 exit and cool down' }
  ];

  function update() {
    var v = parseInt(slider.value);
    var t = (v / 10).toFixed(1);
    tempEl.innerHTML = t + '\u00b0C';
    for(var i = 0; i < zones.length; i++) {
      if(v >= zones[i].min && v < zones[i].max) {
        tempEl.style.color = zones[i].color;
        zoneEl.innerHTML = zones[i].name;
        zoneEl.style.color = zones[i].color;
        descEl.innerHTML = zones[i].desc;
        break;
      }
    }
  }

  slider.addEventListener('input', function() {
    stopped = true;
  });
  update();

  var stopped = false;
  var dir = 1;

  function step() {
    if(stopped) return;
    var v = parseInt(slider.value) + dir;
    if(v > 395) { dir = -1; v = 394; }
    if(v < 370) { dir = 1; v = 371; }
    slider.value = v;
    update();
    if([375, 380, 385, 390, 395, 370].indexOf(v) !== -1) {
      setTimeout(function() { if(!stopped) requestAnimationFrame(stepLoop); }, 1500);
    } else {
      requestAnimationFrame(stepLoop);
    }
  }

  var lastTick = 0;
  function stepLoop(ts) {
    if(stopped) return;
    if(ts - lastTick >= 60) { lastTick = ts; step(); }
    else { requestAnimationFrame(stepLoop); }
  }

  setTimeout(function() { if(!stopped) requestAnimationFrame(stepLoop); }, 2000);
})();
</script>
