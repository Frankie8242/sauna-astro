---
import Layout from '../layouts/Layout.astro';

const homeHref = import.meta.env.BASE_URL;
const privacyHref = `${import.meta.env.BASE_URL}privacy/`;
const supportHref = `${import.meta.env.BASE_URL}support/`;
---

<Layout title="SaunaMind - Know Your Zones">
	<!-- Hidden forms for Netlify build-time detection -->
	<form name="waitlist" data-netlify="true" netlify-honeypot="bot-field" hidden>
		<input type="email" name="email">
	</form>
	<!-- NAV -->
	<nav class="sm-nav">
		<a href={homeHref} class="sm-logo">
			<img src="/logo.png" alt="SaunaMind" width="40" height="40">
			<span class="sm-logo-text">SaunaMind</span>
		</a>
		<div class="sm-nav-links">
			<a class="sm-nav-link" href="#zones">The Science</a>
			<a class="sm-nav-link" href="#research">Research</a>
			<a class="sm-nav-link" href={privacyHref}>Privacy</a>
			<a class="sm-nav-link" href={supportHref}>Support</a>
			<button class="sm-nav-btn" onclick="document.getElementById('join').scrollIntoView({behavior:'smooth'})">Get Early Access</button>
		</div>
	</nav>

	<!-- HERO -->
	<section class="sm-hero">
		<div class="sm-hero-glow"></div><div class="sm-hero-logo-wrap"><img src="/logo.png" alt="SaunaMind" width="160" height="160"><div class="sm-hero-logo-text">SaunaMind</div><div class="sm-hero-logo-sub">Know your zones.</div></div><div class="sm-hero-eyebrow">Science-backed heat tracking</div>
		<h1 class="sm-hero-h1">NOT TIME.<span class="sm-orange">TEMPERATURE.</span></h1>
		<p class="sm-hero-explainer">SaunaMind tracks your sauna sessions using estimated core body temperature — guided by peer-reviewed research, not guesswork.</p>
		<p class="sm-hero-sub">Most people count minutes. The science measures what's actually happening inside your body.</p>
		<div class="sm-trust">
			<div class="sm-trust-item">Based on 20 years of Finnish research</div>
			<div class="sm-trust-item">2,315-person longitudinal study</div>
			<div class="sm-trust-item">Built by health obsessives</div>
		</div>
		<div class="sm-hero-form" id="heroForm">
			<input type="email" class="sm-email-input" id="heroEmail" placeholder="your@email.com">
			<button class="sm-submit-btn" onclick="smSubmit('heroEmail','heroSuccess','heroForm')">Get Early Access</button>
		</div>
		<div class="sm-success" id="heroSuccess">✓ You're on the list.</div>
		<div class="sm-form-note">No spam. Just a notification when we're ready.</div>
		<div class="sm-hero-stat" style="margin-top:48px;">
			<div class="sm-hero-stat-num">63%</div>
			<div class="sm-hero-stat-label">reduction in sudden cardiac death risk · Laukkanen et al., 2018</div>
		</div>
	</section>

	<!-- STATS -->
	<div class="sm-stats">
		<div class="sm-stat"><div class="sm-stat-num">5</div><div class="sm-stat-label">Physiological Zones</div></div>
		<div class="sm-stat"><div class="sm-stat-num">20yr</div><div class="sm-stat-label">Research Foundation</div></div>
		<div class="sm-stat"><div class="sm-stat-num">2,315</div><div class="sm-stat-label">Finnish Study Participants</div></div>
		<div class="sm-stat"><div class="sm-stat-num">5×</div><div class="sm-stat-label">GH Surge at Peak Zone</div></div>
	</div>

	<!-- ZONES -->
	<section id="zones" style="background:#080808;">
		<div class="sm-section">
			<div class="sm-eyebrow">The 5-Zone System</div>
			<h2 class="sm-h2">Heat has <span>zones.</span></h2>
			<p class="sm-section-sub">Estimated core body temperature — not minutes — is what the peer-reviewed research actually tracks.</p>
			<div class="sm-color-bar">
				<div style="background:#8E9AAF"></div><div style="background:#4CAF50"></div>
				<div style="background:#FF9800"></div><div style="background:#E8956A"></div>
				<div style="background:#F44336"></div>
			</div>
			<table class="sm-table">
				<thead><tr><th>Zone</th><th>eCBT Range</th><th>Effect</th><th>Benefit</th></tr></thead>
				<tbody>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:#8E9AAF"></div><span class="sm-zone-name" style="color:#8E9AAF">Warm-Up</span></div></td>
						<td><span class="sm-zone-temp">37.0 – 37.5°C</span></td>
						<td class="sm-zone-desc">Blood flow to skin · mild CV response</td>
						<td><span class="sm-zone-pill" style="background:#0f1015;color:#8E9AAF">Preparation</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:#4CAF50"></div><span class="sm-zone-name" style="color:#4CAF50">Heat Adaptation</span></div></td>
						<td><span class="sm-zone-temp">37.5 – 38.0°C</span></td>
						<td class="sm-zone-desc">Plasma volume ↑ · CV system adapting</td>
						<td><span class="sm-zone-pill" style="background:#0d1a0d;color:#4CAF50">Endurance</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:#FF9800"></div><span class="sm-zone-name" style="color:#FF9800">HSP Activation</span></div></td>
						<td><span class="sm-zone-temp">38.0 – 38.5°C</span></td>
						<td class="sm-zone-desc">Heat shock proteins · cellular repair begins</td>
						<td><span class="sm-zone-pill" style="background:#1a1000;color:#FF9800">Recovery</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:#E8956A"></div><span class="sm-zone-name" style="color:#E8956A">Deep Hormesis</span></div></td>
						<td><span class="sm-zone-temp">38.5 – 39.0°C</span></td>
						<td class="sm-zone-desc">GH 2–5× baseline · BDNF rises · longevity markers peak</td>
						<td><span class="sm-zone-pill" style="background:#1a0f08;color:#E8956A">Longevity</span></td>
					</tr>
					<tr>
						<td><div class="sm-zone-cell"><div class="sm-zone-dot" style="background:#F44336"></div><span class="sm-zone-name" style="color:#F44336">Caution</span></div></td>
						<td><span class="sm-zone-temp">39.0°C+</span></td>
						<td class="sm-zone-desc">Heat stress risk zone · benefits plateau</td>
						<td><span class="sm-zone-pill" style="background:#1a0808;color:#F44336">Risk Zone</span></td>
					</tr>
				</tbody>
			</table>
			<div class="sm-formula-box">
				<div class="sm-formula-label">Why not time?</div>
				<p class="sm-formula-p">Two people spending 15 minutes in the same sauna will reach completely different core temperatures — depending on fitness, resting heart rate, and acclimatisation.<br><br><strong>Time is a guess. Core temperature is the data.</strong></p>
			</div>
		</div>
	</section>

	<!-- SAUNA TYPES -->
	<section style="background:#080808;">
		<div class="sm-section">
			<div class="sm-eyebrow">Sauna Types</div>
			<h2 class="sm-h2">Compare <span>your heat.</span></h2>
			<p class="sm-section-sub">All three raise core temperature. But they reach your zones at very different speeds. Here's what the research shows.</p>
			<table class="sm-cmp-table">
				<thead>
					<tr>
						<th></th>
						<th style="color:#4CAF50;">Infrared</th>
						<th style="color:#E8956A;">Traditional</th>
						<th style="color:#8E9AAF;">Steam Room</th>
					</tr>
				</thead>
				<tbody>
					<tr><td>Temperature</td><td>45–60°C</td><td>80–100°C</td><td>40–50°C</td></tr>
					<tr><td>Session length</td><td>30–45 min</td><td>10–20 min</td><td>15–20 min</td></tr>
					<tr><td>Time to Zone 3</td><td>~25–40 min</td><td>~10–15 min</td><td>~30–45 min</td></tr>
					<tr><td>Heat method</td><td>Tissue direct</td><td>Air → skin</td><td>Humid air</td></tr>
					<tr><td>CV impact</td><td>Moderate</td><td>High</td><td>Moderate</td></tr>
					<tr><td>Research</td><td>Growing</td><td>20+ years</td><td>Limited</td></tr>
				</tbody>
				<tfoot>
					<tr>
						<td></td>
						<td><span class="sm-type-badge" style="background:rgba(76,175,80,0.12);color:#4CAF50;">Longer sessions</span></td>
						<td><span class="sm-type-badge" style="background:rgba(232,149,106,0.12);color:#E8956A;">Fastest to zone</span></td>
						<td><span class="sm-type-badge" style="background:rgba(142,154,175,0.12);color:#8E9AAF;">Slowest rise</span></td>
					</tr>
				</tfoot>
			</table>
			<div style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#2a2a2a; margin-top:24px;">Minson et al. · American Journal of Physiology</div>
		</div>
	</section>

	<!-- SCIENCE -->
	<section id="research" style="background:#060606; padding:20px 0 0 0;">
		<div class="sm-section">
			<div class="sm-eyebrow">Peer-Reviewed Research</div>
			<h2 class="sm-h2">The data <span>behind it.</span></h2>
			<p class="sm-section-sub" style="margin-bottom:0">Every zone threshold is grounded in published research. Not wellness trends. Not guesswork.</p>
			<div class="sm-science-grid">
				<div class="sm-sci-card"><h3>Cardiovascular Protection</h3><p>Regular sauna use at sufficient core temperatures reduces risk of sudden cardiac death by up to 63% in the largest longitudinal study of its kind.</p><div class="sm-sci-source">Laukkanen et al. · JAMA Internal Medicine · 2018</div></div>
				<div class="sm-sci-card"><h3>Growth Hormone Surge</h3><p>Heat stress triggers a growth hormone surge of 2–5× baseline. The response is dose-dependent — more pronounced at higher core temperatures.</p><div class="sm-sci-source">Casanueva et al.</div></div>
				<div class="sm-sci-card"><h3>Heat Shock Proteins</h3><p>HSP70 and HSP90 activate when core temperature crosses ~38°C. These molecular chaperones repair damaged proteins and reduce inflammation.</p><div class="sm-sci-source">Hussain et al. · Journal of Applied Physiology · 2019</div></div>
				<div class="sm-sci-card"><h3>BDNF — Brain Growth Factor</h3><p>Brain-derived neurotrophic factor rises significantly with heat exposure. Linked to improved mood, neuroplasticity, and cognitive protection.</p><div class="sm-sci-source">Rhonda Patrick · FoundMyFitness</div></div>
				<div class="sm-sci-card"><h3>Cortisol Reduction</h3><p>Post-session cortisol drops significantly. Heat activates the parasympathetic nervous system — the same pathway triggered by meditation.</p><div class="sm-sci-source">Laukkanen et al. · Kukkonen-Harjula et al.</div></div>
				<div class="sm-sci-card"><h3>Norepinephrine Spike</h3><p>Norepinephrine spikes up to 3× during heat exposure — sharpening focus and mood. The effect extends well beyond the session itself.</p><div class="sm-sci-source">Srámek et al. · Journal of Applied Physiology · 2000</div></div>
			</div>
		</div>
	</section>

	<!-- WAITLIST -->
	<section class="sm-waitlist" id="join">
		<div class="sm-waitlist-glow"></div>
		<div class="sm-waitlist-inner">
			<h2>GET <span>EARLY<br>ACCESS</span></h2>
			<p class="sm-waitlist-p">Join the community being built around the science of heat.<br>No fluff. No guesswork. Just evidence-based protocols.</p>
			<div class="sm-waitlist-form" id="wForm">
				<input type="email" class="sm-email-input" id="wEmail" placeholder="your@email.com">
				<button class="sm-submit-btn" onclick="smSubmit('wEmail','wSuccess','wForm')">Get Early Access</button>
			</div>
			<div class="sm-success" id="wSuccess">✓ You're on the list. We'll be in touch.</div>
			<div class="sm-form-note" style="margin-top:16px;">No spam. Just a notification when we're ready.</div>
		</div>
	</section>

	<!-- TEMP SLIDER -->
	<section style="background:#080808; border-top:1px solid #161616;">
		<div class="sm-slider-wrap">
			<div class="sm-eyebrow" style="margin-bottom:24px;">Explore the zones</div>
			<div class="sm-slider-temp" id="sliderTemp">37.0°C</div>
			<div class="sm-slider-zone" id="sliderZone" style="color:#8E9AAF;">Warm-Up</div>
			<div class="sm-slider-desc" id="sliderDesc">Blood flow to skin · mild CV response</div>
			<div class="sm-slider-track">
				<input type="range" class="sm-slider-input" id="smTempSlider" min="370" max="395" value="370" step="1">
			</div>
			<div class="sm-slider-range"><span>37.0°C</span><span>39.5°C</span></div>
		</div>
	</section>
</Layout>



<script>
async function smSubmit(inputId, successId, formId) {
  var input = document.getElementById(inputId);
  var success = document.getElementById(successId);
  var form = document.getElementById(formId);
  if(!input || !input.value || !input.value.includes('@')) {
    input.style.borderColor='#F44336';
    setTimeout(function(){ input.style.borderColor=''; }, 1500);
    return;
  }
  var btn = form ? form.querySelector('button') : null;
  if(btn) { btn.textContent='Sending...'; btn.disabled=true; }
  try {
    var body = new URLSearchParams({'form-name':'waitlist', email: input.value}).toString();
    var res = await fetch('/', {
      method:'POST',
      headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body: body
    });
    if(res.ok) {
      if(form) form.style.display='none';
      input.style.display='none';
      success.style.display='block';
    } else {
      if(btn) { btn.textContent='Try again'; btn.disabled=false; }
      input.style.borderColor='#F44336';
    }
  } catch(e) {
    if(btn) { btn.textContent='Try again'; btn.disabled=false; }
    input.style.borderColor='#F44336';
  }
}

var smFacts = [
  { num:'63%', label:'reduction in sudden cardiac death risk · Laukkanen et al., 2018' },
  { num:'2–5×', label:'growth hormone surge at peak core temperature · Casanueva et al.' },
  { num:'40%', label:'lower risk of all-cause mortality with regular sauna · Laukkanen et al.' },
  { num:'3×', label:'norepinephrine spike during heat exposure · Srámek et al., 2000' },
  { num:'46%', label:'lower hypertension risk in women using sauna regularly · Zaccardi et al.' },
  { num:'38°C', label:'core temp threshold for heat shock protein activation · Hussain et al.' },
  { num:'77%', label:'lower dementia risk in men using sauna 4–7× per week · Laukkanen et al.' },
  { num:'2,315', label:'participants in the largest sauna longevity study · Finnish cohort' },
  { num:'↑BDNF', label:'heat exposure boosts brain growth factor linked to mood · Rhonda Patrick' },
  { num:'20yr', label:'of peer-reviewed Finnish sauna research · University of Eastern Finland' },
  { num:'33°C', label:'optimal testicular temp for sperm production after heat · Mieusset et al.' },
  { num:'5°C', label:'below body temp — keep it cool post-sauna to protect fertility · WJMH' }
];
var smFactIndex = 0;
setInterval(function() {
  var box = document.querySelector('.sm-hero-stat');
  if(!box) return;
  box.classList.add('sm-fade-out');
  setTimeout(function() {
    smFactIndex = (smFactIndex + 1) % smFacts.length;
    box.querySelector('.sm-hero-stat-num').innerHTML = smFacts[smFactIndex].num;
    box.querySelector('.sm-hero-stat-label').innerHTML = smFacts[smFactIndex].label;
    box.classList.remove('sm-fade-out');
  }, 600);
}, 8000);

(function() {
  var slider = document.getElementById('smTempSlider');
  var tempEl = document.getElementById('sliderTemp');
  var zoneEl = document.getElementById('sliderZone');
  var descEl = document.getElementById('sliderDesc');
  if(!slider || !tempEl || !zoneEl || !descEl) return;

  var zones = [
    { min:370, max:375, name:'Warm-Up', color:'#8E9AAF', desc:'Blood flow to skin · mild cardiovascular response' },
    { min:375, max:380, name:'Heat Adaptation', color:'#4CAF50', desc:'Sweating peaks · plasma volume expansion begins' },
    { min:380, max:385, name:'HSP Activation', color:'#FF9800', desc:'Heat shock proteins deploy · cellular repair activated' },
    { min:385, max:390, name:'Deep Hormesis', color:'#E8956A', desc:'Growth hormone surges · maximum cardiovascular benefit' },
    { min:390, max:396, name:'Caution', color:'#F44336', desc:'Diminishing returns · exit and cool down' }
  ];

  function update() {
    var v = parseInt(slider.value);
    var t = (v / 10).toFixed(1);
    tempEl.innerHTML = t + '°C';
    for(var i = 0; i < zones.length; i++) {
      if(v >= zones[i].min && v < zones[i].max) {
        tempEl.style.color = zones[i].color;
        zoneEl.innerHTML = zones[i].name;
        zoneEl.style.color = zones[i].color;
        descEl.innerHTML = zones[i].desc;
        break;
      }
    }
  }

  slider.addEventListener('input', function() {
    stopped = true;
  });
  update();

  var stopped = false;
  var dir = 1;

  function step() {
    if(stopped) return;
    var v = parseInt(slider.value) + dir;
    if(v > 395) { dir = -1; v = 394; }
    if(v < 370) { dir = 1; v = 371; }
    slider.value = v;
    update();
    if([375, 380, 385, 390, 395, 370].indexOf(v) !== -1) {
      setTimeout(function() { if(!stopped) requestAnimationFrame(stepLoop); }, 1500);
    } else {
      requestAnimationFrame(stepLoop);
    }
  }

  var lastTick = 0;
  function stepLoop(ts) {
    if(stopped) return;
    if(ts - lastTick >= 60) { lastTick = ts; step(); }
    else { requestAnimationFrame(stepLoop); }
  }

  setTimeout(function() { if(!stopped) requestAnimationFrame(stepLoop); }, 2000);
})();
</script>
