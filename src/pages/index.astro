<script is:inline>
var smFacts = [
  { num:'63%', label:'reduction in sudden cardiac death risk \u00b7 Laukkanen et al., 2018' },
  { num:'2\u20135\u00d7', label:'growth hormone surge at peak heat adaptation \u00b7 Casanueva et al.' },
  { num:'40%', label:'lower risk of all-cause mortality with regular sauna \u00b7 Laukkanen et al.' },
  { num:'3\u00d7', label:'norepinephrine spike during heat exposure \u00b7 Sr\u00e1mek et al., 2000' },
  { num:'46%', label:'lower hypertension risk in women using sauna regularly \u00b7 Zaccardi et al.' },
  { num:'38\u00b0C', label:'thermal threshold for heat shock protein activation \u00b7 Hussain et al.' },
  { num:'77%', label:'lower dementia risk in men using sauna 4\u20137\u00d7 per week \u00b7 Laukkanen et al.' },
  { num:'2,315', label:'participants in the largest sauna longevity study \u00b7 Finnish cohort' },
  { num:'\u2191BDNF', label:'heat exposure boosts brain growth factor linked to mood \u00b7 Rhonda Patrick' },
  { num:'20yr', label:'of peer-reviewed Finnish sauna research \u00b7 University of Eastern Finland' },
  { num:'33\u00b0C', label:'optimal testicular temp for sperm production after heat \u00b7 Mieusset et al.' },
  { num:'5\u00b0C', label:'below body temp \u2014 keep it cool post-sauna to protect fertility \u00b7 WJMH' }
];
var smFactIndex = 0;
setInterval(function() {
  var box = document.querySelector('.sm-hero-stat');
  if(!box) return;
  box.classList.add('sm-fade-out');
  setTimeout(function() {
    smFactIndex = (smFactIndex + 1) % smFacts.length;
    box.querySelector('.sm-hero-stat-num').innerHTML = smFacts[smFactIndex].num;
    box.querySelector('.sm-hero-stat-label').innerHTML = smFacts[smFactIndex].label;
    box.classList.remove('sm-fade-out');
  }, 600);
}, 8000);

(function() {
  var zones = [
    { temp:'37.0\u00b0C', name:'Warm-Up', color:'#3B8BF5', desc:'Blood flow to skin \u00b7 mild cardiovascular response' },
    { temp:'37.5\u00b0C', name:'Heat Adaptation', color:'#22D47A', desc:'Sweating peaks \u00b7 plasma volume expansion begins' },
    { temp:'38.0\u00b0C', name:'HSP Activation', color:'#F5A623', desc:'Heat shock proteins deploy \u00b7 cellular repair activated' },
    { temp:'38.5\u00b0C', name:'Deep Hormesis', color:'#F53B3B', desc:'Growth hormone surges \u00b7 maximum cardiovascular benefit' },
    { temp:'39.0\u00b0C', name:'Caution', color:'#C41717', desc:'Diminishing returns \u00b7 exit and cool down' }
  ];

  var tempEl = document.getElementById('zoneTemp');
  var nameEl = document.getElementById('zoneName');
  var descEl = document.getElementById('zoneDesc');
  var bars = document.querySelectorAll('.zone-bar');
  if(!tempEl || !bars.length) return;

  var current = 0;
  var stopped = false;

  function setZone(i) {
    current = i;
    var z = zones[i];
    tempEl.innerHTML = z.temp;
    tempEl.style.color = z.color;
    nameEl.innerHTML = z.name;
    nameEl.style.color = z.color;
    descEl.innerHTML = z.desc;
    bars.forEach(function(b, idx) {
      b.classList.toggle('active', idx === i);
    });
  }

  bars.forEach(function(bar, idx) {
    bar.addEventListener('click', function() {
      stopped = true;
      setZone(idx);
    });
  });

  setZone(0);

  function autoStep() {
    if(stopped) return;
    current = (current + 1) % zones.length;
    setZone(current);
    setTimeout(autoStep, 2500);
  }
  setTimeout(autoStep, 3000);
})();
</script>
